<div class="language-switcher h-100">

    <div class="language-switcher-container w-100 h-100 align-items-center justify-content-center ps-3 border-start border-light-subtle d-none d-lg-flex">
        <div class="dropdown dropdown-center">
            <button class="dropdown-toggle bg-transparent border-0 text-uppercase fw-light" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                {{ current_lang }}
            </button>
            <ul class="dropdown-menu">
                {% for key, item in links %}
                    {% set code = item.language_code %}
                    <li class="{{ item.is_active ? 'is-active' : '' }}" lang="{{ code }}">
                        <a class="dropdown-item text-uppercase fw-light" href="{{ item.url }}" hreflang="{{ code }}">
                            {{ code|lower }}
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </div>
    </div>

    <div class="lang-switcher-mobile d-lg-none d-block">
        <ul class="lang-list">
            {% for key, item in links %}
                {% set code = item.language_code %}
                <li class="{{ item.is_active ? 'is-active' : '' }}" lang="{{ code }}">
                    {% if item.is_active %}
                        {{ code }}
                    {% else %}
                        <a href="{{ item.url }}" hreflang="{{ code }}">
                            {{ code }}
                        </a>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    </div>

</div>